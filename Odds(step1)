def parse_scoreboard_to_df(scoreboard_data):
    """Parse ESPN scoreboard JSON into a pandas DataFrame of team-level game info"""
    
    games_list = []
    
    for event in scoreboard_data.get("events", []):
        competition = event["competitions"][0]
        competitors = competition["competitors"]
        
        neutral = competition.get("neutralSite", False)
        event_id = event.get("id")
        game_date = event.get("date")
        
        for competitor in competitors:
            team_id = competitor["team"]["id"]
            opponent = [c for c in competitors if c["team"]["id"] != team_id][0]
            opponent_id = opponent["team"]["id"]
            
            games_list.append({
                "team_id": team_id,
                "opponent_id": opponent_id,
                "home_away": competitor["homeAway"],
                "neutral": neutral,
                "event_id": event_id,
                "game_date": game_date
            })
    
    return pd.DataFrame(games_list)


