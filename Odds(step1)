def calculate_days_between(date_str_1, date_str_2):
    """Calculate days between two ISO format date strings"""
    try:
        dt1 = datetime.fromisoformat(date_str_1.replace("Z", "+00:00"))
        dt2 = datetime.fromisoformat(date_str_2.replace("Z", "+00:00"))
        return (dt2 - dt1).days
    except:
        return None


