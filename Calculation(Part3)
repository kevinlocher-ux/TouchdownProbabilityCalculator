# -------------------------
# DEPTH CHART PARSING
# -------------------------

def parse_depth_chart_strings():
    OFFENSIVE_FORMATION_POSITIONS = {"qb", "rb", "te", "wr1", "wr2", "wr3"}
    player_ranks = {}

    script_dir = os.path.dirname(os.path.abspath(__file__))
    depth_chart_dir = os.path.join(script_dir, "Team Depth Charts")

    files = [
        os.path.join(depth_chart_dir, f)
        for f in os.listdir(depth_chart_dir)
        if f.startswith("team_depthchart_") and f.endswith(".json")
    ]

    if not files:
        print(f"⚠️  No depth chart files found in {depth_chart_dir}")
        return player_ranks

    print(f"📂 Found {len(files)} depth chart files")

    for filepath in files:
        with open(filepath, "r") as f:
            data = json.load(f)

        for formation in data.get("depthchart", []):
            positions = formation.get("positions", {})

            # Skip formations that don't contain any offensive skill positions
            if not any(slot in positions for slot in OFFENSIVE_FORMATION_POSITIONS):
                continue

            # --- WRs: slot-first flattening ---
            # Rank 1 = WR1 string 1, Rank 2 = WR2 string 1, Rank 3 = WR3 string 1,
            # Rank 4 = WR1 string 2, Rank 5 = WR2 string 2, etc.
            wr_slots = ["wr1", "wr2", "wr3"]
            present_wr_slots = [s for s in wr_slots if s in positions]

            if present_wr_slots:
                max_wr_depth = max(
                    len(positions[slot]["athletes"])
                    for slot in present_wr_slots
                )

                wr_rank = 1
                for string_num in range(max_wr_depth):
                    for slot in wr_slots:
                        if slot not in positions:
                            continue
                        athletes = positions[slot]["athletes"]
                        if string_num < len(athletes):
                            name = athletes[string_num]["displayName"]
                            if name not in player_ranks or wr_rank < player_ranks[name]:
                                player_ranks[name] = wr_rank
                        wr_rank += 1

            # --- RB, TE, QB: simple string depth ---
            for slot in ["rb", "te", "qb"]:
                if slot not in positions:
                    continue
                for string_num, athlete in enumerate(positions[slot]["athletes"]):
                    name = athlete["displayName"]
                    rank = string_num + 1
                    if name not in player_ranks or rank < player_ranks[name]:
                        player_ranks[name] = rank

    print(f"✅ Parsed depth chart strings for {len(player_ranks)} players")
    return player_ranks

