def score_players(df, position_weights, stat_columns, include_odds=True):
    """
    Calculates a weighted vector magnitude for each player, then applies
    a depth chart scalar as a post-calculation multiplier.

    Formula: sqrt(w1*x1^2 + w2*x2^2 + ... + wn*xn^2) * depth_scalar

    - Players with any value of 99 in any feature column are skipped (missing data).
    - Players whose position is not in position_weights are skipped.
    - depth_rank NaN is treated as rank 1 (starter assumed if no depth chart data).
    - Players beyond rank 4 for WR/RB/TE use a fallback scalar of 0.20.
    - QBs have no depth scalar applied.
    """
    if include_odds:
        feature_columns = ["consensus_prob"] + stat_columns
    else:
        feature_columns = stat_columns

    scores = []
    skipped = []

    for _, row in df.iterrows():
        position = row[COL_POSITION]

        if position not in position_weights:
            scores.append(np.nan)
            continue

        params = position_weights[position]

        if len(params) != len(feature_columns):
            raise ValueError(
                f"params length ({len(params)}) must match "
                f"number of feature columns ({len(feature_columns)})"
            )

        feature_values = row[feature_columns].values.astype(float)

        if 99.0 in feature_values:
            scores.append(np.nan)
            skipped.append(row[COL_PLAYER])
            continue

        weights = np.array(params, dtype=float)
        weighted_sq = (feature_values ** 2) * weights
        raw_score = np.sqrt(weighted_sq.sum())

        # Depth rank — default to 1 if missing
        depth_rank = row["depth_rank"]
        depth_rank = int(depth_rank) if pd.notna(depth_rank) else 1

        if position == "WR":
            scalar = STRING_SCALARS_WR.get(depth_rank, 0.20)
        elif position == "RB":
            scalar = STRING_SCALARS_RB.get(depth_rank, 0.20)
        elif position == "TE":
            scalar = STRING_SCALARS_TE.get(depth_rank, 0.20)
        else:
            scalar = 1.0  # QB — no scalar applied

        scores.append(raw_score * scalar)

    if skipped:
        print(f"⚠️  Skipped {len(skipped)} players due to missing data: {skipped}")

    df = df.copy()
    df["score"] = scores
    return df

