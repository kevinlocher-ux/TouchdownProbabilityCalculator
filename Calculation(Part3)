# -------------------------
# AMERICAN ODDS → IMPLIED PROBABILITY (0-100 scale)
# -------------------------

def american_to_implied(odds_str):
    """Convert American odds to implied probability as a percentage (0-100)."""
    try:
        odds = float(str(odds_str).replace("+", "").strip())
        if odds >= 0:
            prob = 100 / (odds + 100)
        else:
            prob = abs(odds) / (abs(odds) + 100)
        return round(prob * 100, 2)
    except (ValueError, TypeError):
        return np.nan

for col in ODDS_COLUMNS:
    if col in df.columns:
        df[col] = df[col].apply(american_to_implied)

df["consensus_prob"] = df[ODDS_COLUMNS].apply(
    lambda row: round(np.nanmean(row.tolist()), 2), axis=1
)

# -------------------------
# RANK CONVERSIONS
# -------------------------

def rank_to_pct(rank, higher_is_better=True):
    """
    Convert a 1-32 NFL rank to a 0-100 percentage.
    higher_is_better=True  → rank 1 = 100% (own offensive ranks)
    higher_is_better=False → rank 1 = 3.1% (opponent defensive ranks,
                             where rank 32 = worst defense = easiest matchup)
    """
    try:
        rank = int(rank)
        if higher_is_better:
            return round((32 - rank + 1) / 32 * 100, 2)
        else:
            return round(rank / 32 * 100, 2)
    except (ValueError, TypeError):
        return 0.0

# Opponent defensive ranks — rank 32 (worst defense) = easiest matchup = high %
df["Opposing Defense Rushing Rank"] = df["Opposing Defense Rushing Rank"].apply(
    lambda x: rank_to_pct(x, higher_is_better=False)
)
df["Opposing Defense Passing rank"] = df["Opposing Defense Passing rank"].apply(
    lambda x: rank_to_pct(x, higher_is_better=False)
)

# Own offensive ranks — rank 1 (best offense) = high %
df["Own passing offense rank"] = df["Own passing offense rank"].apply(
    lambda x: rank_to_pct(x, higher_is_better=True)
)
df["Own rushing offense rank"] = df["Own rushing offense rank"].apply(
